{
    "image": "mcr.microsoft.com/devcontainers/base:debian-13",
    "features": {
        "ghcr.io/devcontainers/features/common-utils:2": {
            "configureZshAsDefaultShell": true
        },
        "ghcr.io/devcontainers/features/git:1": {},
        "ghcr.io/devcontainers-extra/features/claude-code:1": {},
        "ghcr.io/devcontainers-extra/features/starship:1": {},
        "ghcr.io/devcontainers/features/python": {
            "version": "3.12",
            "installTools": false
        },
        "ghcr.io/va-h/devcontainers-features/uv": {}
    },
    "mounts": [
        "source=${localEnv:HOME}${localEnv:USERPROFILE}/.claude,target=/home/vscode/.claude,type=bind,consistency=cached",
        "source=${localEnv:HOME}${localEnv:USERPROFILE}/.claude.json,target=/home/vscode/.claude.json,type=bind,consistency=cached"
    ],
    "postCreateCommand": "bash .devcontainer/postCreate.sh",
    "customizations": {
        "vscode": {
            "settings": {
                "git.autorefresh": true,
                "git.autofetch": true,
                "security.workspace.trust.enabled": false
            },
            "extensions": [
                "Anthropic.claude-code",
                "dracula-theme.theme-dracula",
                "mhutchie.git-graph",
                "george-alisson.html-preview-vscode",
                "PKief.material-icon-theme",
                "ionutvmi.path-autocomplete",
                "ms-vscode-remote.remote-containers",
                "cweijan.epub-reader"
            ]
        }
    }

}
